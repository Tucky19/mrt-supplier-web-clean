generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rfq {
  id          String     @id @default(cuid())
  requestId   String     @unique
  createdAt   DateTime   @default(now())
  company     String?
  name        String?
  phone       String?
  email       String?
  note        String?
  contactPref String?
  ipHash      String?
  lineId      String?
  source      String     @default("web")
  status      RfqStatus  @default(new)
  updatedAt   DateTime   @updatedAt
  userAgent   String?
  leadId      String?
  quotedAt     DateTime?
  quoteRef     String?
  quotedBy     String?
  quoteAmount  Decimal?  @db.Decimal(12, 2)
  quoteCurrency String?
  validUntil   DateTime?
  quoteDocumentUrl String?
  quoteSentAt      DateTime?
  quoteSentNote    String?
  followUps   FollowUp[]
  lead        Lead?      @relation(fields: [leadId], references: [id])
  events      RfqEvent[]
  items       RfqItem[]
  notes      RfqNote[]
  assignedTo       String?
  assignedAt       DateTime?

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([leadId, createdAt])
}

model RfqItem {
  id        String   @id @default(cuid())
  rfqId     String
  productId String
  partNo    String
  brand     String?
  category  String?
  title     String?
  spec      String?
  qty       Int
  createdAt DateTime @default(now())
  meta      Json?
  rfq       Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId])
  @@index([partNo])
}

model RfqEvent {
  id        String       @id @default(cuid())
  rfqId     String
  type      RfqEventType
  payload   Json?
  createdAt DateTime     @default(now())
  rfq       Rfq          @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId, createdAt])
  @@index([type, createdAt])
}

model FollowUp {
  id        String    @id @default(cuid())
  rfqId     String
  note      String?
  dueAt     DateTime
  doneAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  rfq       Rfq       @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId, dueAt])
  @@index([doneAt, dueAt])
}

model RfqRateLimit {
  id          String   @id @default(cuid())
  ipHash      String
  windowStart DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([ipHash, windowStart])
  @@index([windowStart])
}

model Lead {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  lineId    String?  @unique
  company   String?
  name      String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rfqs      Rfq[]

  @@index([createdAt])
}

enum RfqStatus {
  new
  in_progress
  quoted
  closed
  spam
}

enum RfqEventType {
  created
  emailed_admin
  emailed_customer
  email_failed
  viewed
  status_changed
  note
  follow_up
  quote_record
  quote_document
  owner_assigned
}
model RfqNote {
  id         String   @id @default(cuid())
  rfqId      String
  body       String   @db.Text
  createdAt  DateTime @default(now())

  rfq        Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId, createdAt])
}