generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rfq {
  id               String    @id @default(cuid())
  requestId        String    @unique
  createdAt        DateTime  @default(now())
  company          String?
  name             String?
  phone            String?
  email            String?
  note             String?
  contactPref      String?
  ipHash           String?
  lineId           String?
  source           String    @default("web")
  status           RfqStatus @default(new)
  updatedAt        DateTime  @updatedAt
  userAgent        String?
  leadId           String?
  quotedAt         DateTime?
  quoteRef         String?
  quotedBy         String?
  quoteAmount      Decimal?  @db.Decimal(12, 2)
  quoteCurrency    String?
  validUntil       DateTime?
  quoteDocumentUrl String?
  quoteSentAt      DateTime?
  quoteSentNote    String?
  assignedTo       String?
  assignedAt       DateTime?

  lead      Lead?      @relation(fields: [leadId], references: [id])
  followUps FollowUp[]
  events    RfqEvent[]
  items     RfqItem[]
  notes     RfqNote[]

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([leadId, createdAt])
}

model RfqItem {
  id        String   @id @default(cuid())
  rfqId     String
  productId String?
  partNo    String
  brand     String?
  category  String?
  title     String?
  spec      String?
  qty       Int
  createdAt DateTime @default(now())
  meta      Json?

  rfq       Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId])
  @@index([partNo])
  @@index([productId])
}

model RfqEvent {
  id        String       @id @default(cuid())
  rfqId     String
  type      RfqEventType
  payload   Json?
  createdAt DateTime     @default(now())

  rfq Rfq @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId, createdAt])
  @@index([type, createdAt])
}

model FollowUp {
  id        String    @id @default(cuid())
  rfqId     String
  note      String?
  dueAt     DateTime
  doneAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  rfq Rfq @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId, dueAt])
  @@index([doneAt, dueAt])
}

model RfqRateLimit {
  id          String   @id @default(cuid())
  ipHash      String
  windowStart DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([ipHash, windowStart])
  @@index([windowStart])
}

model Lead {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  lineId    String?  @unique
  company   String?
  name      String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rfqs Rfq[]

  @@index([createdAt])
}

model RfqNote {
  id        String   @id @default(cuid())
  rfqId     String
  body      String   @db.Text
  createdAt DateTime @default(now())

  rfq Rfq @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId, createdAt])
}

model Product {
  id               String        @id @default(cuid())
  partNo           String
  normalizedPartNo String        @unique
  brand            String
  category         String?
  title            String
  titleTh          String?
  titleEn          String?
  spec             String?
  description      String?       @db.Text
  unit             String?
  status           ProductStatus @default(active)
  isFeatured       Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  supplierPrices SupplierPrice[]
  crossRefsFrom  CrossReference[] @relation("CrossRefFrom")
  crossRefsTo    CrossReference[] @relation("CrossRefTo")

  @@index([partNo])
  @@index([brand])
  @@index([category])
  @@index([brand, category])
  @@index([createdAt])
}

model CrossReference {
  id              String             @id @default(cuid())
  fromProductId   String
  toProductId     String
  relationType    CrossReferenceType @default(equivalent)
  confidenceScore Decimal?           @db.Decimal(5, 2)
  note            String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  fromProduct Product @relation("CrossRefFrom", fields: [fromProductId], references: [id], onDelete: Cascade)
  toProduct   Product @relation("CrossRefTo", fields: [toProductId], references: [id], onDelete: Cascade)

  @@unique([fromProductId, toProductId])
  @@index([fromProductId])
  @@index([toProductId])
}

model Supplier {
  id               String         @id @default(cuid())
  name             String
  code             String         @unique
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  lineId           String?
  currency         String         @default("THB")
  reliabilityScore Decimal?       @db.Decimal(4, 2)
  leadTimeMinDays  Int?
  leadTimeMaxDays  Int?
  note             String?        @db.Text
  status           SupplierStatus @default(active)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  prices SupplierPrice[]

  @@index([name])
  @@index([status])
}

model SupplierPrice {
  id              String      @id @default(cuid())
  supplierId      String
  productId       String
  supplierPartNo  String?
  costAmount      Decimal     @db.Decimal(12, 2)
  currency        String      @default("THB")
  freightAmount   Decimal     @default(0) @db.Decimal(12, 2)
  handlingAmount  Decimal     @default(0) @db.Decimal(12, 2)
  importAmount    Decimal     @default(0) @db.Decimal(12, 2)
  totalCostAmount Decimal     @db.Decimal(12, 2)
  availableQty    Int?
  minOrderQty     Int         @default(1)
  leadTimeDays    Int?
  isPreferred     Boolean     @default(false)
  validUntil      DateTime?
  stockStatus     StockStatus @default(in_stock)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId, supplierPartNo])
  @@index([supplierId])
  @@index([productId])
  @@index([stockStatus])
}

enum RfqStatus {
  new
  in_progress
  quoted
  closed
  spam
}

enum RfqEventType {
  created
  emailed_admin
  emailed_customer
  email_failed
  viewed
  status_changed
  note
  follow_up
  quote_record
  quote_document
  owner_assigned
}

enum ProductStatus {
  active
  inactive
}

enum SupplierStatus {
  active
  inactive
}

enum CrossReferenceType {
  equivalent
  alternative
  possible_match
}

enum StockStatus {
  in_stock
  limited
  preorder
  unavailable
}
model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String   // search | click | rfq
  query     String?
  partNo    String?
  productId String?
  sessionId String
  createdAt DateTime @default(now())

  @@index([type])
  @@index([query])
  @@index([createdAt])
}
model SearchEvent {
  id          String   @id @default(cuid())
  type        String   // 'search' | 'click_result' | 'add_to_quote'
  query       String?
  partNo      String?
  matchType   String?
  resultCount Int?
  ipHash      String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([query])
}